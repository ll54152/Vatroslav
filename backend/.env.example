# Database
DB_NAME=name_of_your_database_here
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here
ADMIN_FIRSTNAME=ADMIN_FIRSTNAME
ADMIN_LASTNAME=ADMIN_LASTNAME

# Email Configuration (Gmail as example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password_here

APP_FRONTEND_URL=your_frontend_url_here
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://your_frontend_url_here